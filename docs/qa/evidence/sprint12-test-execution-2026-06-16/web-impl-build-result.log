# [A] 清理历史构建产物
cd E:/claude/smart-workshop-erp/web-impl
rm -rf dist
rm -rf node_modules/.vite

# [B] 执行 build
npm run build 2>&1 | tee build.log
echo "exit code: $?"                       # 期望：0

# [C] 关键断言
grep -E "vite v[0-9]+\.[0-9]+\.[0-9]+ building" build.log
grep -E "✓ built in [0-9]+(\.[0-9]+)?(s|ms)" build.log
# 期望：✓ built in 30-60s

grep -E "vue-tsc -b" build.log
grep -E "error TS[0-9]+" build.log | wc -l # 期望：0
# 期望：vue-tsc 0 错误 + vite 0 错误

# [D] dist 标题验证（V1.3.8）
grep -rE "<title>.*</title>" dist/index.html
# 期望：<title>Smart Workshop ERP V1.3.8</title>  或 V1.3.8 含 sprint 12 字样

# [E] dist 大小统计
du -sh dist/
ls -la dist/assets/ | head -20
# 期望：dist 总大小 < 5MB · js/css 资源有 content-hash 文件名

# [F] 拷贝证据归档
