{
  "name": "erp-web",
  "version": "1.3.8",
  "private": true,
  "type": "module",
  "description": "昆山佰泰胜专属 ERP 系统 V1.3.8 - Web Frontend (Vue 3) · 6 Story SHARDED (2.1/3.1/3.2/4.1/4.2/4.3)",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --port 5173 --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,scss}\"",
    "type-check": "vue-tsc --noEmit",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:ci": "vue-tsc --noEmit && git diff --exit-code src/api/generated",
    "api:gen": "openapi -i ../backend/spec/openapi.yaml -o src/api/generated -c fetch --useUnionTypes",
    "gen:api": "openapi -i ../backend/spec/openapi.yaml -o src/api/generated -c fetch --useUnionTypes",
    "msw:init": "msw init public/ --save",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "gap:smoke": "node scripts/gap-matrix-smoke.mjs"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@vueuse/core": "^10.11.0",
    "axios": "^1.7.2",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.11",
    "echarts": "^5.5.0",
    "element-plus": "^2.7.6",
    "lodash-es": "^4.17.21",
    "pdfjs-dist": "^4.0.379",
    "pinia": "^2.1.7",
    "qrcode": "^1.5.3",
    "vue": "^3.4.27",
    "vue-draggable-next": "^2.3.0",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.3.3",
    "vxe-table": "^4.19.14",
    "xe-utils": "^4.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/vue3-vite": "^8.6.18",
    "@types/crypto-js": "^4.2.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.5",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^1.6.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.5.0",
    "msw": "^2.3.1",
    "openapi-typescript-codegen": "^0.29.0",
    "prettier": "^3.3.2",
    "sass": "^1.77.4",
    "storybook": "^8.6.18",
    "typescript": "~5.4.5",
    "unplugin-auto-import": "^0.17.6",
    "unplugin-vue-components": "^0.27.0",
    "vite": "^5.2.13",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.1.10"
  }
}
