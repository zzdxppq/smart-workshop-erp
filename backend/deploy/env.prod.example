# 复制到服务器 /opt/deploy/env.prod 并填写真实值
PROFILE=prod

# ---------- 镜像（本地 push-images 推送后填写）----------
ERP_IMAGE_REGISTRY=registry.cn-hangzhou.aliyuncs.com/kczj
ERP_IMAGE_TAG=1.3.7
# MINIO_IMAGE=minio/minio:RELEASE.2024-05-10T01-41-38Z

# ---------- 服务端口（宿主机 = 容器，9 开头）----------
ERP_GATEWAY_PORT=9080
ERP_PLATFORM_PORT=9081
ERP_BUSINESS_PORT=9082
ERP_PRODUCTION_PORT=9083

# ---------- MySQL / Redis（Redis 与 ERP 同机 compose 服务名 redis）----------
MYSQL_HOST=10.100.4.10
MYSQL_PORT=3306
MYSQL_USER=xm_admin
MYSQL_PASSWORD=change-me

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=change-me
REDIS_TIMEOUT=3000ms
REDIS_IMAGE=registry.cn-hangzhou.aliyuncs.com/kczj/redis:7.2
REDIS_MAXMEMORY=1gb

# ---------- Nacos / XXL-JOB（Docker 内勿用 127.0.0.1，填宿主机内网 IP）----------
NACOS_SERVER=10.100.6.14:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
NACOS_NAMESPACE=prod
# Bootstrap 阶段 Nacos Config 只认 Spring 标准 env（不认 NACOS_SERVER 别名）
SPRING_CLOUD_NACOS_CONFIG_SERVER_ADDR=10.100.6.14:8848
SPRING_CLOUD_NACOS_DISCOVERY_SERVER_ADDR=10.100.6.14:8848
SPRING_CLOUD_NACOS_CONFIG_USERNAME=nacos
SPRING_CLOUD_NACOS_DISCOVERY_USERNAME=nacos
SPRING_CLOUD_NACOS_CONFIG_PASSWORD=nacos
SPRING_CLOUD_NACOS_DISCOVERY_PASSWORD=nacos
SPRING_CLOUD_NACOS_CONFIG_NAMESPACE=prod
SPRING_CLOUD_NACOS_DISCOVERY_NAMESPACE=prod

XXL_JOB_ADMIN=http://10.100.6.14:8080/xxl-job-admin
XXL_JOB_TOKEN=

WEB_BASE_URL=https://bts.51xiaoping.com
API_BASE_URL=https://bts.51xiaoping.com

XXL_JOB_APPNAME_GATEWAY=xxl-job-erp-gateway
XXL_JOB_APPNAME_PLATFORM=xxl-job-erp-platform
XXL_JOB_APPNAME_BUSINESS=xxl-job-erp-business
XXL_JOB_APPNAME_PRODUCTION=xxl-job-erp-production

XXL_JOB_PORT_GATEWAY=9990
XXL_JOB_PORT_PLATFORM=9991
XXL_JOB_PORT_BUSINESS=9992
XXL_JOB_PORT_PRODUCTION=9993

JWT_SECRET=change-me

# 163 SMTP（platform · PUT /email/config 或 configure-email-smtp.mjs）
EMAIL_163_FROM=your-account@163.com
EMAIL_163_AUTH_CODE=change-me-163-auth-code

# 微服务间 Feign（docker-compose 内网；HR 建档创建 sys_user 依赖 PLATFORM_SERVICE_URL）
PRODUCTION_SERVICE_URL=http://erp-production:9083
PLATFORM_SERVICE_URL=http://erp-platform:9081
BUSINESS_SERVICE_URL=http://erp-business:9082

# 微服务内部 API（Feign /internal/** · 请求头 X-Internal-Token；business + production 必填）
ERP_INTERNAL_TOKEN=change-me-internal-token

# MinIO（compose 内 ERP 用 http://minio:9000；控制台 http://10.100.6.14:9001）
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=erp-minio
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_ROOT_USER=erp-minio
MINIO_ROOT_PASSWORD=change-me-minio-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_DRAWING=erp-drawing
