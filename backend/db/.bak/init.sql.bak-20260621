    ('BOM-20260612-0002', 'v1', 2, 'DWG-20260612-0002', 'STANDARD', 50, 'WL-1002', 18750.00, '[{"name":"原材料","cost":3000.00},{"name":"粗加工","cost":2250.00},{"name":"精加工","cost":3750.00},{"name":"表面处理","cost":5500.00},{"name":"检验","cost":4250.00}]', NULL, 0, 'RELEASED', 1002, 1002, '2026-06-12 10:30:00'),
    ('BOM-20260612-0003', 'v1', 5, 'DWG-20260612-0005', 'STANDARD', 200, 'WL-1005', 88000.00, '[{"name":"原材料","cost":30000.00},{"name":"粗加工","cost":4000.00},{"name":"精加工","cost":44000.00},{"name":"表面处理","cost":8000.00},{"name":"检验","cost":2000.00}]', NULL, 0, 'RELEASED', 1002, 1002, '2026-06-12 11:00:00'),
    ('BOM-20260612-0004', 'v1', 3, 'DWG-20260612-0003', 'STANDARD', 1, 'WL-1003', 480.00, '[{"name":"原材料","cost":180.00},{"name":"粗加工","cost":95.00},{"name":"精加工","cost":130.00},{"name":"表面处理","cost":25.00},{"name":"检验","cost":50.00}]', NULL, 0, 'DRAFT', 1001, NULL, NULL),
    ('BOM-20260612-0005', 'v1', 4, 'DWG-20260612-0004', 'STANDARD', 1, 'WL-1004', 325.00, '[{"name":"原材料","cost":90.00},{"name":"粗加工","cost":70.00},{"name":"精加工","cost":120.00},{"name":"表面处理","cost":30.00},{"name":"检验","cost":15.00}]', NULL, 0, 'DRAFT', 1003, NULL, NULL);

