-- include: V17__outsource.sql
-- V1.3.7 · Story 1.18 · 委外下单基础
-- 迁移：crm_outsource_order 委外单 + crm_outsource_item 委外明细 + crm_outsource_history 委外历史

CREATE TABLE IF NOT EXISTS crm_outsource_order (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    outsource_no VARCHAR(32) NOT NULL UNIQUE COMMENT 'WW{yyyyMMdd}{seq:4}（复用 1.4 prefix）',
    workorder_no VARCHAR(32) COMMENT '关联工单',
    step_no INT COMMENT '工序号',
    supplier_id BIGINT NOT NULL COMMENT '供应商ID',
    supplier_name VARCHAR(128) COMMENT '供应商名称',
    process_name VARCHAR(64) COMMENT '工序名称',
    material_code VARCHAR(32) COMMENT '委外物料',
    drawing_id BIGINT NULL COMMENT '加工图纸 ID（crm_drawing.id）',
    qty INT NOT NULL DEFAULT 0 COMMENT '数量',
    unit_price DECIMAL(18,4) DEFAULT 0 COMMENT '单价',
    total_amount DECIMAL(18,4) DEFAULT 0 COMMENT '总金额 = unit_price × qty',
    delivery_date DATE COMMENT '交期',
    status VARCHAR(16) DEFAULT 'DRAFT' COMMENT 'DRAFT/SENT/ACCEPTED/IN_PRODUCTION/INSPECTED/COMPLETED/CLOSED/REWORK',
    rework_count INT DEFAULT 0 COMMENT '返修次数（≤ 3）',
    creator_user_id BIGINT COMMENT 'creator_userID',
    submitted_at DATETIME COMMENT 'submitted时间',
    accepted_at DATETIME COMMENT 'accepted时间',
    completed_at DATETIME COMMENT '完成时间',
    closed_at DATETIME COMMENT 'closed时间',
    is_urgent TINYINT(1) DEFAULT 0 COMMENT '加急',
    remark VARCHAR(255) COMMENT '备注',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
    INDEX idx_outsource_status (status),
    INDEX idx_outsource_supplier (supplier_id),
    INDEX idx_outsource_workorder (workorder_no),
    INDEX idx_outsource_drawing (drawing_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.18 · 委外下单基础表';

CREATE TABLE IF NOT EXISTS crm_outsource_item (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    outsource_no VARCHAR(32) NOT NULL COMMENT '委外单号',
    item_seq INT NOT NULL COMMENT '明细seq',
    material_code VARCHAR(32) NOT NULL COMMENT '物料编码',
    material_name VARCHAR(128) COMMENT '物料名称',
    spec VARCHAR(255) COMMENT '规格',
    qty INT NOT NULL COMMENT '数量',
    unit VARCHAR(16) DEFAULT '个' COMMENT '单位',
    unit_price DECIMAL(18,4) DEFAULT 0 COMMENT '单价',
    total_amount DECIMAL(18,4) DEFAULT 0 COMMENT '总金额',
    delivery_date DATE COMMENT '交期',
    remark VARCHAR(255) COMMENT '备注',
    INDEX idx_item_outsource (outsource_no)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.18 · 委外下单基础表';

CREATE TABLE IF NOT EXISTS crm_outsource_history (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    outsource_no VARCHAR(32) NOT NULL COMMENT '委外单号',
    operation VARCHAR(32) NOT NULL COMMENT 'CREATE/SUBMIT/ACCEPT/START/INSPECT/COMPLETE/CLOSE/REWORK',
    operator_user_id BIGINT COMMENT '操作人用户ID',
    operated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT 'operated时间',
    from_status VARCHAR(16) COMMENT 'fromstatus',
    to_status VARCHAR(16) COMMENT 'tostatus',
    note VARCHAR(255) COMMENT 'note',
    INDEX idx_history_outsource (outsource_no)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.18 · 委外下单基础表';

