('PP20260601-0001', 301, '上海汽车配件', 5001, 'XS20260501-0001', 1, 'RV20260601-0001', 120000.00, 120000.00,     0.00, DATE_ADD(CURDATE(), INTERVAL 10 DAY),  'PENDING',         NULL,                       NULL, '远期'),
('PP20260601-0002', 302, '北京精密机械', 5002, 'XS20260505-0002', 2, 'RV20260601-0002',  80000.00,  80000.00,     0.00, DATE_ADD(CURDATE(), INTERVAL  2 DAY),  'ALERT',           NULL,                       NULL, 'P1 修补 2：提前 3 天 ALERT'),
('PP20260601-0003', 303, '深圳五金制品', 5003, 'XS20260510-0003', 3, 'RV20260601-0003',  50000.00,  30000.00, 20000.00, DATE_SUB(CURDATE(), INTERVAL 15 DAY),  'PENDING',         DATE_SUB(NOW(), INTERVAL 25 DAY), 701, '部分回款 · 未完成'),
('PP20260601-0004', 304, '苏州电机股份', 5004, 'XS20260512-0004', 4, 'RV20260601-0004', 200000.00, 150000.00, 50000.00, DATE_SUB(CURDATE(), INTERVAL 60 DAY),  'ALERT_CRITICAL',  DATE_SUB(NOW(), INTERVAL 30 DAY), 701, 'P1 修补 3：逾期 60 天'),
('PP20260601-0005', 305, '杭州仪器仪表', 5005, 'XS20260515-0005', 5, 'RV20260601-0005',  65000.00,  65000.00, 65000.00, DATE_SUB(CURDATE(), INTERVAL 95 DAY),  'PAID',            DATE_SUB(NOW(), INTERVAL 90 DAY), 701, '已回款');

