-- include: V48__quality_pickup.sql
-- V1.3.7 · Story 1.51 · 委外协同·品质领料后质检
CREATE TABLE IF NOT EXISTS crm_quality_pickup (
    id BIGINT AUTO_INCREMENT PRIMARY KEY COMMENT '主键ID',
    pickup_no VARCHAR(64) NOT NULL COMMENT 'pickup编号',
    scan_no VARCHAR(64) NULL COMMENT '扫码单号',
    inspector_id BIGINT NULL COMMENT 'inspectorID',
    inspector_name VARCHAR(64) NULL COMMENT 'inspector名称',
    vendor_name VARCHAR(128) NULL COMMENT '厂商名称',
    pickup_type VARCHAR(32) NULL COMMENT 'pickuptype',
    inspect_status VARCHAR(32) NULL COMMENT 'inspectstatus',
    total_count INT NOT NULL DEFAULT 0 COMMENT 'totalcount',
    pass_count INT NOT NULL DEFAULT 0 COMMENT 'passcount',
    fail_count INT NOT NULL DEFAULT 0 COMMENT 'failcount',
    email VARCHAR(128) NULL COMMENT '邮箱',
    pickup_time DATETIME NOT NULL COMMENT 'pickuptime',
    inspected_at DATETIME NULL COMMENT 'inspected时间',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    UNIQUE KEY uk_pickup_no (pickup_no),
    KEY idx_scan (scan_no),
    KEY idx_inspector (inspector_id),
    KEY idx_status (inspect_status)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='品质领料单';

CREATE TABLE IF NOT EXISTS crm_quality_pickup_item (
    id BIGINT AUTO_INCREMENT PRIMARY KEY COMMENT '主键ID',
    pickup_item_no VARCHAR(64) NOT NULL COMMENT 'pickup_item编号',
    pickup_no VARCHAR(64) NOT NULL COMMENT 'pickup编号',
    material_code VARCHAR(64) NULL COMMENT '物料编码',
    material_name VARCHAR(128) NULL COMMENT '物料名称',
    quantity INT NOT NULL DEFAULT 0 COMMENT '数量',
    inspect_result VARCHAR(16) NULL COMMENT 'inspect结果',
    defect_desc VARCHAR(256) NULL COMMENT '不良desc',
    measure_value DECIMAL(18,4) NULL COMMENT 'measurevalue',
    inspect_time DATETIME NULL COMMENT 'inspecttime',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    UNIQUE KEY uk_pickup_item_no (pickup_item_no),
    KEY idx_pickup (pickup_no),
    KEY idx_result (inspect_result)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='品质领料明细';

