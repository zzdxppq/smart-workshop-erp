-- include: V16__mrp.sql
-- V1.3.7 · Story 1.17 · MRP 物料需求分析
-- 迁移：crm_mrp_run MRP 运算记录 + crm_mrp_result MRP 结果 + crm_mrp_shortage 缺料清单

CREATE TABLE IF NOT EXISTS crm_mrp_run (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    run_no VARCHAR(32) NOT NULL UNIQUE COMMENT 'MR{yyyyMMdd}{seq:4}',
    run_type VARCHAR(16) DEFAULT 'FULL' COMMENT 'FULL / INCREMENTAL',
    date_range_start DATE COMMENT '日期范围起',
    date_range_end DATE COMMENT '日期范围止',
    warehouse_ids VARCHAR(255) COMMENT '仓库 ID 列表（逗号分隔）',
    status VARCHAR(16) DEFAULT 'RUNNING' COMMENT 'RUNNING / COMPLETED / FAILED',
    started_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '开始时间',
    completed_at DATETIME COMMENT '完成时间',
    total_shortage INT DEFAULT 0 COMMENT '缺料总数',
    total_purchase_suggestion INT DEFAULT 0 COMMENT '建议采购总量',
    triggered_by BIGINT COMMENT '触发人用户ID',
    remark VARCHAR(255) COMMENT '备注',
    INDEX idx_mrp_run_status (status)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.17 · MRP 物料需求分析表';

CREATE TABLE IF NOT EXISTS crm_mrp_result (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    run_id BIGINT NOT NULL COMMENT '运算ID',
    material_code VARCHAR(32) NOT NULL COMMENT '物料编码',
    material_name VARCHAR(128) COMMENT '物料名称',
    required_qty INT NOT NULL COMMENT '需求数量',
    current_stock INT DEFAULT 0 COMMENT '当前库存',
    on_order_qty INT DEFAULT 0 COMMENT '在途数量',
    shortage_qty INT DEFAULT 0 COMMENT '缺料数量',
    purchase_suggestion INT DEFAULT 0 COMMENT '建议采购量',
    supplier_id BIGINT COMMENT '供应商ID',
    unit_cost DECIMAL(18,4) DEFAULT 0 COMMENT 'unit成本',
    total_cost DECIMAL(18,4) DEFAULT 0 COMMENT '总成本',
    INDEX idx_result_run (run_id),
    INDEX idx_result_material (material_code)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.17 · MRP 物料需求分析表';

CREATE TABLE IF NOT EXISTS crm_mrp_shortage (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    run_id BIGINT NOT NULL COMMENT '运算ID',
    material_code VARCHAR(32) NOT NULL COMMENT '物料编码',
    shortage_qty INT NOT NULL COMMENT '缺料数量',
    required_date DATE COMMENT 'required日期',
    priority INT DEFAULT 5 COMMENT '优先级',
    source_workorders TEXT COMMENT '关联工单号（逗号分隔）',
    INDEX idx_shortage_run (run_id),
    INDEX idx_shortage_priority (priority)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.17 · MRP 物料需求分析表';

