-- include: V41__dashboard_production.sql
-- V1.3.7 · Story 1.44 · 报表·生产工作台
CREATE TABLE IF NOT EXISTS crm_dashboard_production (
    id BIGINT AUTO_INCREMENT PRIMARY KEY COMMENT '主键ID',
    snapshot_no VARCHAR(64) NOT NULL COMMENT '快照编号',
    workorder_no VARCHAR(64) NULL COMMENT '工单号',
    product_name VARCHAR(128) NULL COMMENT '产品名称',
    workorder_status VARCHAR(16) NULL COMMENT 'PENDING/RUNNING/PAUSED/DONE',
    qty_planned INT NOT NULL DEFAULT 0 COMMENT 'qtyplanned',
    qty_completed INT NOT NULL DEFAULT 0 COMMENT 'qtycompleted',
    progress DECIMAL(5,2) NOT NULL DEFAULT 0 COMMENT 'progress',
    alert_type VARCHAR(16) NULL COMMENT 'INFO/WARN/CRITICAL',
    alert_message VARCHAR(500) NULL COMMENT '告警message',
    snapshot_at DATETIME NOT NULL COMMENT '快照时间',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    UNIQUE KEY uk_snapshot_no (snapshot_no),
    KEY idx_dash_status (workorder_status),
    KEY idx_dash_alert (alert_type)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='生产看板快照';

