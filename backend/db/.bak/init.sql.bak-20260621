-- include: V70__drawing_material_sync_menu.sql
-- V70 · 图纸物料编码与 crm_material 对齐 + 生管/工程师条码菜单权限
USE `cnc_business`;

-- 图纸已有 material_code 但 crm_material 缺失时补建（料号查询依赖）
INSERT IGNORE INTO `crm_material` (
  `material_code`, `material_name`, `spec`, `unit`, `category_id`,
  `cost_material`, `cost_labor`, `cost_machine`, `cost_overhead`, `cost_outsource`, `cost_total`,
  `is_active`, `dept_id`, `remark`
)
SELECT
  d.material_code,
  d.title,
  '图纸关联',
  '个',
  3,
  0, 0, 0, 0, 0, 0,
  1,
  10,
  CONCAT('V70 由图纸 ', d.drawing_no, ' 同步')
FROM `crm_drawing` d
LEFT JOIN `crm_material` m ON m.material_code = d.material_code
WHERE m.id IS NULL;

