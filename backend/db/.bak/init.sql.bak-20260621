INSERT INTO `crm_outsource_cost_aggregation` (`outsource_id`, `outsource_no`, `material_code`, `process_name`, `cost_material`, `cost_labor`, `cost_machine`, `cost_overhead`, `cost_outsource`, `cost_total`, `budget_cost`, `deviation_pct`, `deviation_level`, `aggregation_scope`, `created_by`) VALUES
