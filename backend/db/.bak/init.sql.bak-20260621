('RF20260612-0003', 'Q235 法兰毛坯 200 件',     1004, 'M-Q235-FLG', 'Q235 法兰毛坯',200.00, 'PCS',  20000.00, '2026-07-25', 'QUOTING',  'LOWEST',   501);

