     '[{"name":"原材料","cost":120.50},{"name":"粗加工","cost":80.00},{"name":"精加工","cost":200.00},{"name":"表面处理","cost":150.00},{"name":"检验","cost":90.00}]'),
    (2, 'DWG-20260612-0002', 'v1', 'BOM-20260612-0002', 'STANDARD', 50, 375.00, 1002, '李工程师', 'CONVERTED',
     '[{"step":1,"name":"锻造","cost":60.00},{"step":2,"name":"车削","cost":45.00},{"step":3,"name":"滚齿","cost":75.00},{"step":4,"name":"热处理","cost":110.00},{"step":5,"name":"磨齿","cost":85.00}]',
     '[{"name":"原材料","cost":60.00},{"name":"粗加工","cost":45.00},{"name":"精加工","cost":75.00},{"name":"表面处理","cost":110.00},{"name":"检验","cost":85.00}]'),
    (5, 'DWG-20260612-0005', 'v1', 'BOM-20260612-0003', 'STANDARD', 200, 440.00, 1002, '李工程师', 'CONVERTED',
     '[{"step":1,"name":"压铸","cost":150.00},{"step":2,"name":"去毛刺","cost":20.00},{"step":3,"name":"CNC加工","cost":220.00},{"step":4,"name":"检测","cost":40.00},{"step":5,"name":"入库","cost":10.00}]',
     '[{"name":"原材料","cost":150.00},{"name":"粗加工","cost":20.00},{"name":"精加工","cost":220.00},{"name":"表面处理","cost":40.00},{"name":"检验","cost":10.00}]'),
    (3, 'DWG-20260612-0003', 'v1', NULL, 'STANDARD', 1, 480.00, 1001, '张工程师', 'FAILED',
