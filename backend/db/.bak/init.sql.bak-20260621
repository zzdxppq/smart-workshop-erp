-- WW20260612-0003 IN_PRODUCTION (1-3-4) / WW20260612-0004 COMPLETED (1-2-3-4-5-6) / WW20260612-0005 DRAFT (1)

-- 复用 seed：state_history 与 history 表并存（state_history 强调 outsource_id + transition_type，history 强调 outsource_no + operation）
-- WW20260612-0001 SENT 全状态轨迹
INSERT INTO crm_outsource_state_history (outsource_id, outsource_no, from_state, to_state, transition_type, operator_user_id, operator_role, reason) VALUES
(1, 'WW20260612-0001', NULL,       'DRAFT',         'ADVANCE',  2,  '生管', '创建委外单'),
