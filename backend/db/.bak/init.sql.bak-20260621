-- include: V47__warehouse_incoming_scan.sql
-- V1.3.7 · Story 1.50 · 委外协同·仓管到货扫码
CREATE TABLE IF NOT EXISTS crm_warehouse_incoming_scan (
    id BIGINT AUTO_INCREMENT PRIMARY KEY COMMENT '主键ID',
    scan_no VARCHAR(64) NOT NULL COMMENT '扫码单号',
    permission_no VARCHAR(64) NULL COMMENT '权限编号',
    user_id BIGINT NULL COMMENT '用户ID',
    vendor_name VARCHAR(128) NULL COMMENT '厂商名称',
    outsource_no VARCHAR(64) NULL COMMENT '委外单号',
    scan_type VARCHAR(32) NULL COMMENT '扫码类型',
    scan_status VARCHAR(32) NULL COMMENT '扫码status',
    total_count INT NOT NULL DEFAULT 0 COMMENT 'totalcount',
    email VARCHAR(128) NULL COMMENT '邮箱',
    scan_time DATETIME NOT NULL COMMENT '扫码time',
    confirmed_at DATETIME NULL COMMENT 'confirmed时间',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    UNIQUE KEY uk_scan_no (scan_no),
    KEY idx_permission (permission_no),
    KEY idx_user (user_id),
    KEY idx_status (scan_status)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='仓管扫码';

CREATE TABLE IF NOT EXISTS crm_warehouse_incoming_item (
    id BIGINT AUTO_INCREMENT PRIMARY KEY COMMENT '主键ID',
    item_no VARCHAR(64) NOT NULL COMMENT '明细编号',
    scan_no VARCHAR(64) NOT NULL COMMENT '扫码单号',
    barcode VARCHAR(64) NULL COMMENT '条码',
    barcode_type VARCHAR(16) NULL COMMENT '条码type',
    material_code VARCHAR(64) NULL COMMENT '物料编码',
    material_name VARCHAR(128) NULL COMMENT '物料名称',
    quantity INT NOT NULL DEFAULT 0 COMMENT '数量',
    batch_no VARCHAR(64) NULL COMMENT '批次号',
    warehouse_location VARCHAR(64) NULL COMMENT '仓库库位',
    remark VARCHAR(256) NULL COMMENT '备注',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    UNIQUE KEY uk_item_no (item_no),
    KEY idx_scan (scan_no),
    KEY idx_barcode (barcode)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='仓管扫码明细';

