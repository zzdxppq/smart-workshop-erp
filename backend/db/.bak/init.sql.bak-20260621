('OI20260612-0005', 1, 'WW20260612-0001', 101, '上海热处理厂',  'ZZ-0002', 5,  3,  2, 40.00, 'FAILED', 301, '2026-07-11 16:00:00', 'qa@btsheng-163.com', 301);

