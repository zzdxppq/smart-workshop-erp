-- include: V31__incoming_alert.sql
-- V1.3.7 · Story 1.34 · 采购·到货提醒 (FR-8-3)
-- 迁移：crm_incoming_alert 到货提醒 + crm_incoming 实际到货
-- 3 P1 修补：预估到货日必填 / 提前 3 天 ALERT / 逾期 ALERT_CRITICAL / 唯一索引 (po_id, material_id)
-- 模板：IA{yyyyMMdd}{seq:4}

USE `cnc_business`;

-- 到货提醒（PO 创建时生成）
CREATE TABLE IF NOT EXISTS `crm_incoming_alert` (
  `id` BIGINT NOT NULL AUTO_INCREMENT COMMENT '主键ID',
  `alert_no` VARCHAR(32) NOT NULL COMMENT 'IA{yyyyMMdd}{seq:4}',
  `po_id` BIGINT NOT NULL COMMENT '采购单ID',
  `po_no` VARCHAR(32) NOT NULL COMMENT '采购单号',
  `vendor_id` BIGINT DEFAULT NULL COMMENT '厂商ID',
  `vendor_name` VARCHAR(128) DEFAULT NULL COMMENT '厂商名称',
  `material_id` BIGINT NOT NULL COMMENT '物料ID',
  `material_code` VARCHAR(64) DEFAULT NULL COMMENT '物料编码',
  `material_name` VARCHAR(255) DEFAULT NULL COMMENT '物料名称',
  `qty` DECIMAL(12,2) NOT NULL COMMENT '数量',
  `unit` VARCHAR(16) DEFAULT NULL COMMENT '单位',
  `expected_date` DATE NOT NULL COMMENT '预估到货日 · P1 修补 1 必填',
  `alert_level` VARCHAR(20) NOT NULL DEFAULT 'PENDING' COMMENT 'PENDING/ALERT（提前 3 天）/ALERT_CRITICAL（逾期）/ARRIVED',
  `alert_message` VARCHAR(500) DEFAULT NULL COMMENT '告警message',
  `arrived_qty` DECIMAL(12,2) DEFAULT NULL COMMENT 'arrived数量',
  `arrived_at` DATETIME DEFAULT NULL COMMENT '到货时间',
  `arrived_by` BIGINT DEFAULT NULL COMMENT 'arrivedby',
  `reminded_at` DATETIME DEFAULT NULL COMMENT 'reminded时间',
  `reminded_count` INT NOT NULL DEFAULT 0 COMMENT 'remindedcount',
  `created_at` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `updated_at` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uniq_alert_po_material` (`po_id`, `material_id`),
  KEY `idx_alert_po` (`po_id`),
  KEY `idx_alert_level` (`alert_level`),
  KEY `idx_alert_expected_date` (`expected_date`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='到货提醒（V1.3.7 Story 1.34 FR-8-3）';

-- 实际到货（扫码入库记录）
CREATE TABLE IF NOT EXISTS `crm_incoming` (
  `id` BIGINT NOT NULL AUTO_INCREMENT COMMENT '主键ID',
  `incoming_no` VARCHAR(32) NOT NULL COMMENT 'IN{yyyyMMdd}{seq:4}',
  `alert_id` BIGINT NOT NULL COMMENT '告警ID',
  `po_id` BIGINT NOT NULL COMMENT '采购单ID',
  `po_no` VARCHAR(32) NOT NULL COMMENT '采购单号',
  `vendor_id` BIGINT DEFAULT NULL COMMENT '厂商ID',
  `vendor_name` VARCHAR(128) DEFAULT NULL COMMENT '厂商名称',
  `material_id` BIGINT NOT NULL COMMENT '物料ID',
  `material_code` VARCHAR(64) DEFAULT NULL COMMENT '物料编码',
  `material_name` VARCHAR(255) DEFAULT NULL COMMENT '物料名称',
  `arrived_qty` DECIMAL(12,2) NOT NULL COMMENT 'arrived数量',
  `expected_qty` DECIMAL(12,2) NOT NULL COMMENT 'expected数量',
  `unit` VARCHAR(16) DEFAULT NULL COMMENT '单位',
  `arrived_at` DATETIME NOT NULL COMMENT '到货时间',
  `arrived_by` BIGINT NOT NULL COMMENT 'arrivedby',
  `quality_status` VARCHAR(16) NOT NULL DEFAULT 'PENDING' COMMENT 'PENDING/PASS/FAIL',
  `scan_batch_no` VARCHAR(32) DEFAULT NULL COMMENT '关联 1.12 扫码批次号',
  `remark` VARCHAR(500) DEFAULT NULL COMMENT '备注',
  `created_at` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  PRIMARY KEY (`id`),
  KEY `idx_incoming_alert` (`alert_id`),
  KEY `idx_incoming_po` (`po_id`),
  KEY `idx_incoming_material` (`material_id`),
  KEY `idx_incoming_arrived_at` (`arrived_at`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='实际到货（V1.3.7 Story 1.34 FR-8-3）';

-- Seed 5 提醒：3 在途（含 1 提前 ALERT）+ 1 逾期 ALERT_CRITICAL + 1 已到货 ARRIVED
INSERT INTO `crm_incoming_alert` (`alert_no`, `po_id`, `po_no`, `vendor_id`, `vendor_name`, `material_id`, `material_code`, `material_name`, `qty`, `unit`, `expected_date`, `alert_level`, `alert_message`, `arrived_qty`, `arrived_at`, `reminded_at`, `reminded_count`) VALUES
('IA20260612-0001', 1, 'PO20260401-0001', 901, '上海铝业',  1001, 'M-AL6061-PT', '6061 铝板 T6',  100.00, 'PCS', DATE_ADD(CURDATE(), INTERVAL 7 DAY),  'PENDING',         '距离到货还有 7 天',                NULL, NULL,                     NULL, 0),
