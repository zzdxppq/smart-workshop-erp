-- include: V12__warehouse_location.sql
-- V1.3.7 · Story 1.13 · 库位批次与多仓库
-- 迁移：crm_warehouse 仓库 + crm_warehouse_location 库位（升级版） + crm_batch 批次

CREATE TABLE IF NOT EXISTS crm_warehouse (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    warehouse_code VARCHAR(32) NOT NULL UNIQUE COMMENT '仓库编码',
    warehouse_name VARCHAR(64) NOT NULL COMMENT '仓库名称',
    warehouse_type VARCHAR(16) NOT NULL COMMENT 'MAIN / SUB / LINE_SIDE',
    address VARCHAR(255) COMMENT 'address',
    manager_user_id BIGINT COMMENT 'manager_userID',
    is_active TINYINT(1) DEFAULT 1 COMMENT '是否启用(0否1是)',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    INDEX idx_warehouse_type (warehouse_type)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.13 · 库位批次与多仓库表';

CREATE TABLE IF NOT EXISTS crm_batch (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    batch_no VARCHAR(64) NOT NULL UNIQUE COMMENT 'B{yyyyMMdd}{seq:6}',
    material_code VARCHAR(32) NOT NULL COMMENT '物料编码',
    supplier_id BIGINT COMMENT '供应商ID',
    supplier_name VARCHAR(128) COMMENT '供应商名称',
    qty INT NOT NULL DEFAULT 0 COMMENT '数量',
    received_at DATETIME COMMENT 'received时间',
    expired_at DATETIME COMMENT 'expired时间',
    quality_status VARCHAR(16) DEFAULT 'PENDING' COMMENT 'PENDING / PASSED / FAILED',
    location_code VARCHAR(32) COMMENT '库位编码',
    fefo_order INT DEFAULT 0 COMMENT 'FEFO 先入先出排序',
    remark VARCHAR(255) COMMENT '备注',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    INDEX idx_batch_material (material_code),
    INDEX idx_batch_supplier (supplier_id),
    INDEX idx_batch_quality (quality_status)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.13 · 库位批次与多仓库表';

