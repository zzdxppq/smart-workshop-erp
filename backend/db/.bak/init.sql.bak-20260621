-- include: V14__workorder.sql
-- V1.3.7 · Story 1.15 · 工单与排产 · Epic 5
-- 迁移：crm_workorder 工单 + crm_workorder_step 工序 + crm_production_schedule 排产

CREATE TABLE IF NOT EXISTS crm_workorder (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    workorder_no VARCHAR(32) NOT NULL UNIQUE COMMENT 'GD{yyyyMMdd}{seq:4}',
    drawing_id BIGINT COMMENT '图纸ID',
    bom_id BIGINT COMMENT 'BOM ID',
    process_route_id BIGINT COMMENT 'process_routeID',
    material_code VARCHAR(32) NOT NULL COMMENT '物料编码（成品 CP-XXXX）',
    product_name VARCHAR(128) COMMENT '产品名称',
    qty INT NOT NULL DEFAULT 1 COMMENT '数量',
    unit VARCHAR(16) DEFAULT '台' COMMENT '单位',
    priority INT DEFAULT 5 COMMENT '1=紧急 ~ 10=低',
    status VARCHAR(16) DEFAULT 'DRAFT' COMMENT 'DRAFT/SCHEDULED/IN_PROGRESS/COMPLETED/CANCELLED',
    scheduled_start DATETIME COMMENT '排产开始时间',
    scheduled_end DATETIME COMMENT '排产结束时间',
    actual_start DATETIME COMMENT '实际开始时间',
    actual_end DATETIME COMMENT '实际结束时间',
    equipment_id BIGINT COMMENT '机台 ID',
    equipment_type VARCHAR(32) COMMENT '机台类型',
    estimated_hours DECIMAL(10,2) DEFAULT 0 COMMENT '预计工时',
    actual_hours DECIMAL(10,2) DEFAULT 0 COMMENT '实际工时',
    is_fa TINYINT(1) DEFAULT 0 COMMENT '是否首件(0否1是)',
    created_by BIGINT COMMENT '创建人用户ID',
    owner_user_id BIGINT COMMENT '负责人用户ID',
    dept_id BIGINT DEFAULT 10 COMMENT '部门ID',
    remark VARCHAR(255) COMMENT '备注',
    sales_order_id BIGINT NULL COMMENT '销售订单ID',
    sales_order_no VARCHAR(32) NULL COMMENT '销售订单号 XS',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
    INDEX idx_workorder_status (status),
    INDEX idx_workorder_equipment (equipment_id),
    INDEX idx_workorder_priority (priority),
    INDEX idx_workorder_sales_order (sales_order_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.15 · 工单与排产 · Epic 5表';

CREATE TABLE IF NOT EXISTS crm_workorder_step (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    workorder_id BIGINT NOT NULL COMMENT '工单ID',
    step_no INT NOT NULL COMMENT '工序号 1/2/3',
    step_name VARCHAR(64) NOT NULL COMMENT '工序名称',
    equipment_type VARCHAR(32) COMMENT 'equipmenttype',
    estimated_minutes INT DEFAULT 0 COMMENT '预计分钟',
    actual_minutes INT DEFAULT 0 COMMENT '实际分钟',
    status VARCHAR(16) DEFAULT 'PENDING' COMMENT 'PENDING/IN_PROGRESS/COMPLETED',
    started_at DATETIME COMMENT '开始时间',
    completed_at DATETIME COMMENT '完成时间',
    operator_user_id BIGINT COMMENT '操作人用户ID',
    INDEX idx_step_workorder (workorder_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.15 · 工单与排产 · Epic 5表';

CREATE TABLE IF NOT EXISTS crm_production_schedule (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    schedule_no VARCHAR(32) NOT NULL UNIQUE COMMENT 'SCH{yyyyMMdd}{seq:4}',
    workorder_id BIGINT NOT NULL COMMENT '工单ID',
    equipment_id BIGINT NOT NULL COMMENT '设备ID',
    equipment_type VARCHAR(32) COMMENT 'equipmenttype',
    plan_start DATETIME NOT NULL COMMENT '计划开始',
    plan_end DATETIME NOT NULL COMMENT '计划结束',
    status VARCHAR(16) DEFAULT 'PLANNED' COMMENT 'PLANNED/IN_PROGRESS/COMPLETED/CONFLICT',
    conflict_with BIGINT COMMENT '冲突工单 ID',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    INDEX idx_schedule_equipment (equipment_id),
    INDEX idx_schedule_status (status)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.15 · 工单与排产 · Epic 5表';

