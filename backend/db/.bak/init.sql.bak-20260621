-- include: V15__production_scan.sql
-- V1.3.7 · Story 1.16 · APP 扫码开工/报工/过站
-- 迁移：crm_production_scan 生产扫码 + crm_production_report 报工 + crm_production_station 过站

CREATE TABLE IF NOT EXISTS crm_production_scan (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    scan_no VARCHAR(32) NOT NULL UNIQUE COMMENT 'PS{yyyyMMdd}{seq:4}',
    workorder_no VARCHAR(32) NOT NULL COMMENT '工单号 GD-XXXX',
    scan_type VARCHAR(16) NOT NULL COMMENT 'START / REPORT / STATION',
    operator_user_id BIGINT NOT NULL COMMENT '操作人用户ID',
    equipment_id BIGINT COMMENT '设备ID',
    qty INT DEFAULT 0 COMMENT '数量',
    step_no INT COMMENT '工序号',
    scanned_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '扫码时间',
    client_id VARCHAR(64) COMMENT 'APP 客户端 ID',
    sync_status VARCHAR(16) DEFAULT 'SYNCED' COMMENT '同步状态',
    remark VARCHAR(255) COMMENT '备注',
    INDEX idx_ps_workorder (workorder_no),
    INDEX idx_ps_type (scan_type)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.16 · APP 扫码开工/报工/过站表';

CREATE TABLE IF NOT EXISTS crm_production_report (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    report_no VARCHAR(32) NOT NULL UNIQUE COMMENT 'RP{yyyyMMdd}{seq:4}',
    workorder_no VARCHAR(32) NOT NULL COMMENT '工单号',
    step_no INT NOT NULL COMMENT '工序号',
    reported_qty INT NOT NULL DEFAULT 0 COMMENT '报工数量',
    actual_minutes INT DEFAULT 0 COMMENT '实际工时（分钟）',
    is_abnormal TINYINT(1) DEFAULT 0 COMMENT '异常标记',
    abnormal_type VARCHAR(32) COMMENT '异常类型：QUALITY/EQUIPMENT/MATERIAL',
    abnormal_note VARCHAR(255) COMMENT '异常说明',
    reported_by BIGINT NOT NULL COMMENT '报工人ID',
    reported_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '报工时间',
    INDEX idx_report_workorder (workorder_no),
    INDEX idx_report_step (step_no)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.16 · APP 扫码开工/报工/过站表';

CREATE TABLE IF NOT EXISTS crm_production_station (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    transfer_no VARCHAR(32) NOT NULL UNIQUE COMMENT 'TR{yyyyMMdd}{seq:4}',
    workorder_no VARCHAR(32) NOT NULL COMMENT '工单号',
    from_step_no INT NOT NULL COMMENT '源工序',
    to_step_no INT NOT NULL COMMENT '目标工序',
    from_equipment_id BIGINT COMMENT '源设备ID',
    to_equipment_id BIGINT COMMENT '目标设备ID',
    transferred_by BIGINT NOT NULL COMMENT '过站操作人ID',
    transferred_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '过站时间',
    remark VARCHAR(255) COMMENT '备注',
    INDEX idx_station_workorder (workorder_no)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='V1.3.7 · Story 1.16 · APP 扫码开工/报工/过站表';

