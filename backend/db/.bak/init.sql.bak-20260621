-- include: V10__material_barcode.sql
-- V1.3.7 · Story 1.11 · 物料条码生成 · Epic 4
-- 迁移：crm_material_barcode 物料条码 + crm_barcode_history 扫码历史
-- 继承 Story 1.4 (5 类码) + 1.7 (DocNoGenerator) + 1.9 (BOM 多级树)

-- 1. 物料分类表（5 段：原材料/外购件/自制件/委外件/成品）
CREATE TABLE IF NOT EXISTS crm_material_category (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    category_code VARCHAR(32) NOT NULL UNIQUE COMMENT '分类编码：MAT-RAW / MAT-BUY / MAT-MFG / MAT-OUT / MAT-FIN',
    category_name VARCHAR(64) NOT NULL COMMENT '分类名称',
    prefix VARCHAR(8) NOT NULL COMMENT '条码 prefix：WL-原材料 / WJ-外购 / ZZ-自制 / WW-委外 / CP-成品',
    seq_no INT DEFAULT 0 COMMENT '排序',
    is_active TINYINT(1) DEFAULT 1 COMMENT '是否启用(0否1是)',
    remark VARCHAR(255) COMMENT '备注',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
    INDEX idx_category_code (category_code)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='1. 物料分类表（5 段：原材料/外购件/自制件/委外件/成品）';

-- 2. 物料主数据（继承 1.4 / 1.7 / 1.9）
CREATE TABLE IF NOT EXISTS crm_material (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    material_code VARCHAR(32) NOT NULL UNIQUE COMMENT 'WL-XXXX / WJ-XXXX / ZZ-XXXX / WW-XXXX / CP-XXXX',
    material_name VARCHAR(128) NOT NULL COMMENT '物料名称',
    spec VARCHAR(255) COMMENT '规格',
    unit VARCHAR(16) DEFAULT '个' COMMENT '单位',
    category_id BIGINT COMMENT 'FK crm_material_category',
    process_id BIGINT COMMENT 'FK crm_process（工艺路线）',
    cost_material DECIMAL(18,4) DEFAULT 0 COMMENT '5 段成本',
    cost_labor DECIMAL(18,4) DEFAULT 0 COMMENT '人工成本',
    cost_machine DECIMAL(18,4) DEFAULT 0 COMMENT '机台成本',
    cost_overhead DECIMAL(18,4) DEFAULT 0 COMMENT '管理费用',
    cost_outsource DECIMAL(18,4) DEFAULT 0 COMMENT '委外成本',
    cost_total DECIMAL(18,4) DEFAULT 0 COMMENT '5 段总成本',
    is_active TINYINT(1) DEFAULT 1 COMMENT '是否启用(0否1是)',
    owner_user_id BIGINT COMMENT '负责人用户ID',
    dept_id BIGINT DEFAULT 10 COMMENT '部门ID',
    remark VARCHAR(255) COMMENT '备注',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
    INDEX idx_material_category (category_id),
    INDEX idx_material_process (process_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='2. 物料主数据（继承 1.4 / 1.7 / 1.9）表';

-- 3. 物料条码主表（核心表）
CREATE TABLE IF NOT EXISTS crm_material_barcode (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    barcode_no VARCHAR(32) NOT NULL UNIQUE COMMENT 'BC{yyyyMMdd}{seq:4}（DocNoGenerator）',
    material_code VARCHAR(32) NOT NULL COMMENT 'WL-XXXX（FK crm_material）',
    spec VARCHAR(255) COMMENT '规格',
    payload TEXT COMMENT 'AES-256-GCM 加密 payload（material_code + spec + process_id + cost + batch）',
    process_id BIGINT COMMENT '工艺 ID',
    cost_breakdown VARCHAR(1024) COMMENT 'JSON 5 段成本',
    batch_no VARCHAR(64) COMMENT '批次号（1.13 联动）',
    qty INT DEFAULT 1 COMMENT '数量（默认 1）',
    qr_code_url VARCHAR(512) COMMENT '二维码 base64（P2 修补）',
    status VARCHAR(16) DEFAULT 'ACTIVE' COMMENT 'ACTIVE / USED / DISCARDED',
    generated_by BIGINT COMMENT 'generatedby',
    generated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT 'generated时间',
    updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
    INDEX idx_barcode_material (material_code),
    INDEX idx_barcode_status (status),
    INDEX idx_barcode_batch (batch_no)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='3. 物料条码主表（核心表）';

-- 4. 条码扫码历史
CREATE TABLE IF NOT EXISTS crm_barcode_history (
    id BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    barcode_no VARCHAR(32) NOT NULL COMMENT 'FK crm_material_barcode',
    scan_user_id BIGINT NOT NULL COMMENT 'scan_userID',
    scan_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '扫码时间',
    scan_location VARCHAR(128) COMMENT '扫码地点（如：A 仓 / B 仓 / 线边仓）',
    scan_type VARCHAR(16) NOT NULL COMMENT 'GENERATE / PARSE / INBOUND / OUTBOUND / VERIFY',
    scan_result VARCHAR(16) DEFAULT 'SUCCESS' COMMENT 'SUCCESS / FAILED',
    error_msg VARCHAR(255) COMMENT 'errormsg',
    client_type VARCHAR(16) DEFAULT 'WEB' COMMENT 'WEB / ANDROID / IOS',
    remark VARCHAR(255) COMMENT '备注',
    INDEX idx_history_barcode (barcode_no),
    INDEX idx_history_user (scan_user_id),
    INDEX idx_history_at (scan_at)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='4. 条码扫码历史表';

-- 5. Seed 5 类物料分类
INSERT INTO crm_material_category (category_code, category_name, prefix, seq_no) VALUES
