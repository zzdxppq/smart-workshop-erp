-- include: V40__hr_performance_recruitment.sql
-- V1.3.7 · Story 1.43 · 绩效与招聘
CREATE TABLE IF NOT EXISTS crm_hr_performance (
    id BIGINT AUTO_INCREMENT PRIMARY KEY COMMENT '主键ID',
    employee_id BIGINT NOT NULL COMMENT '员工ID',
    employee_no VARCHAR(64) NOT NULL COMMENT '员工编号',
    employee_name VARCHAR(64) NULL COMMENT '员工名称',
    period_year INT NOT NULL COMMENT 'periodyear',
    period_month INT NOT NULL COMMENT 'periodmonth',
    score DECIMAL(5,2) NOT NULL COMMENT 'score',
    grade VARCHAR(8) NULL COMMENT 'A/B/C/D',
    kpi_items TEXT NULL COMMENT 'kpiitems',
    comment VARCHAR(500) NULL COMMENT '备注说明',
    created_by BIGINT NULL COMMENT '创建人用户ID',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    KEY idx_perf_emp (employee_id),
    KEY idx_perf_period (period_year, period_month)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='员工绩效';

CREATE TABLE IF NOT EXISTS crm_hr_recruitment (
    id BIGINT AUTO_INCREMENT PRIMARY KEY COMMENT '主键ID',
    recruitment_no VARCHAR(64) NOT NULL COMMENT 'recruitment编号',
    candidate_name VARCHAR(64) NOT NULL COMMENT 'candidate名称',
    position VARCHAR(64) NULL COMMENT 'position',
    department VARCHAR(64) NULL COMMENT 'department',
    phone VARCHAR(32) NULL COMMENT '手机号',
    email VARCHAR(128) NULL COMMENT '邮箱',
    hr_status VARCHAR(16) NOT NULL DEFAULT 'PENDING' COMMENT 'hrstatus',
    dept_status VARCHAR(16) NOT NULL DEFAULT 'PENDING' COMMENT '部门status',
    hrd_status VARCHAR(16) NOT NULL DEFAULT 'PENDING' COMMENT 'hrdstatus',
    final_status VARCHAR(16) NOT NULL DEFAULT 'RECRUITING' COMMENT 'finalstatus',
    offer_date DATE NULL COMMENT 'offer日期',
    onboard_date DATE NULL COMMENT 'onboard日期',
    created_by BIGINT NULL COMMENT '创建人用户ID',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
    UNIQUE KEY uk_recruitment_no (recruitment_no)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='招聘记录';

