(2, 'WW20260612-0002', 'ZZ-0003', '电镀锌', 30.00,  10.00, 5.00,  3.00,  30.00,  78.00,  80.00,  -2.50, 'WITHIN', 'PROCESS', 201),
(3, 'WW20260612-0003', 'ZZ-0004', '线切割', 200.00, 50.00, 40.00, 20.00, 240.00, 550.00, 500.00,  10.00, 'WARN',   'PROCESS', 201),
(4, 'WW20260612-0004', 'ZZ-0001', '喷涂',   80.00,  20.00, 15.00, 10.00, 120.00, 245.00, 240.00,  2.08, 'WITHIN', 'PROCESS', 201),
