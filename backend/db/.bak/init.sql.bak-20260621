-- include: V65__workorder_sales_order_link.sql
-- V1.3.9 · 工单关联销售订单（AC-5.1.1 订单转工单）
USE `cnc_business`;

SET @col_exists = (SELECT COUNT(*) FROM information_schema.COLUMNS
  WHERE TABLE_SCHEMA = 'cnc_business' AND TABLE_NAME = 'crm_workorder' AND COLUMN_NAME = 'sales_order_id');
SET @sql = IF(@col_exists = 0,
  'ALTER TABLE crm_workorder ADD COLUMN sales_order_id BIGINT NULL COMMENT ''销售订单ID'' AFTER remark, ADD COLUMN sales_order_no VARCHAR(32) NULL COMMENT ''销售订单号 XS'' AFTER sales_order_id, ADD INDEX idx_workorder_sales_order (sales_order_id)',
  'SELECT 1');
PREPARE stmt FROM @sql; EXECUTE stmt; DEALLOCATE PREPARE stmt;

-- 同步至 cnc_production（V60 模式）
CREATE TABLE IF NOT EXISTS `cnc_production`.`crm_workorder` LIKE `cnc_business`.`crm_workorder`;

SET @col_prod = (SELECT COUNT(*) FROM information_schema.COLUMNS
  WHERE TABLE_SCHEMA = 'cnc_production' AND TABLE_NAME = 'crm_workorder' AND COLUMN_NAME = 'sales_order_id');
SET @sql_prod = IF(@col_prod = 0,
  'ALTER TABLE cnc_production.crm_workorder ADD COLUMN sales_order_id BIGINT NULL COMMENT ''销售订单ID'' AFTER remark, ADD COLUMN sales_order_no VARCHAR(32) NULL COMMENT ''销售订单号 XS'' AFTER sales_order_id, ADD INDEX idx_workorder_sales_order (sales_order_id)',
  'SELECT 1');
PREPARE stmt2 FROM @sql_prod; EXECUTE stmt2; DEALLOCATE PREPARE stmt2;

-- include: V66__outsource_drawing_id.sql
-- V1.3.8 · 委外单关联加工图纸（Epic 3 · 采购下单前确认图纸）
USE `cnc_business`;

SET @col_exists = (SELECT COUNT(*) FROM information_schema.COLUMNS
  WHERE TABLE_SCHEMA = 'cnc_business' AND TABLE_NAME = 'crm_outsource_order' AND COLUMN_NAME = 'drawing_id');
SET @sql = IF(@col_exists = 0,
  'ALTER TABLE crm_outsource_order ADD COLUMN drawing_id BIGINT NULL COMMENT ''加工图纸 ID（crm_drawing.id）'' AFTER material_code, ADD INDEX idx_outsource_drawing (drawing_id)',
  'SELECT 1');
PREPARE stmt FROM @sql; EXECUTE stmt; DEALLOCATE PREPARE stmt;

SET @col_prod = (SELECT COUNT(*) FROM information_schema.COLUMNS
  WHERE TABLE_SCHEMA = 'cnc_production' AND TABLE_NAME = 'crm_outsource_order' AND COLUMN_NAME = 'drawing_id');
SET @sql_prod = IF(@col_prod = 0,
  'ALTER TABLE cnc_production.crm_outsource_order ADD COLUMN drawing_id BIGINT NULL COMMENT ''加工图纸 ID（crm_drawing.id）'' AFTER material_code, ADD INDEX idx_outsource_drawing (drawing_id)',
  'SELECT 1');
PREPARE stmt2 FROM @sql_prod; EXECUTE stmt2; DEALLOCATE PREPARE stmt2;

-- include: V54__migrate_drawing_link.sql (data)
-- ============================================================
-- V1.3.9 Sprint 12 Story 12.1 · V54__migrate_drawing_link.sql
-- 5 表 JOIN crm_drawing.material_code 回填 crm_drawing_link
--
-- 执行顺序：在 V54__crm_drawing_link.sql 之后执行
-- 关联 Story：12.1-drawing-permission-matrix
--
-- 数据源（5 张业务单据子表）：
--   1) crm_order_item               → biz_type='ORDER'
--   2) crm_purchase_order_item      → biz_type='PO'
--   3) crm_incoming_order_item      → biz_type='INCOMING'
--   4) crm_inspection_item          → biz_type='INSPECTION'
--   5) crm_workorder_process        → biz_type='WORKORDER_PROCESS'
--
-- 关键约束：
--   - INSERT IGNORE + uk_biz_ref 防重（无需应用层去重）
--   - created_by = 1 (system)
--   - 仅回填 DRAFT/RELEASED 状态图纸
-- ============================================================

USE `cnc_business`;

-- 1) 销售订单 → 图纸
INSERT IGNORE INTO crm_drawing_link (drawing_id, biz_type, biz_id, created_by)
SELECT d.id, 'ORDER', oi.order_id, 1
FROM crm_drawing d
JOIN crm_order_item oi ON oi.material COLLATE utf8mb4_unicode_ci = d.material_code COLLATE utf8mb4_unicode_ci
WHERE d.status IN ('DRAFT', 'RELEASED')
GROUP BY d.id, oi.order_id;

-- 2) 采购单 → 图纸
INSERT IGNORE INTO crm_drawing_link (drawing_id, biz_type, biz_id, created_by)
SELECT d.id, 'PO', poi.purchase_order_id, 1
FROM crm_drawing d
JOIN crm_purchase_order_item poi ON poi.material_code COLLATE utf8mb4_unicode_ci = d.material_code COLLATE utf8mb4_unicode_ci
WHERE d.status IN ('DRAFT', 'RELEASED')
GROUP BY d.id, poi.purchase_order_id;

-- 3) 入库单 → 图纸（crm_incoming · 非 crm_incoming_order_item）
INSERT IGNORE INTO crm_drawing_link (drawing_id, biz_type, biz_id, created_by)
SELECT d.id, 'INCOMING', inc.id, 1
FROM crm_drawing d
JOIN crm_incoming inc ON inc.material_code COLLATE utf8mb4_unicode_ci = d.material_code COLLATE utf8mb4_unicode_ci
WHERE d.status IN ('DRAFT', 'RELEASED')
GROUP BY d.id, inc.id;

-- 4) 质检单 → 图纸（crm_quality_inspection · 非 crm_inspection_item）
INSERT IGNORE INTO crm_drawing_link (drawing_id, biz_type, biz_id, created_by)
SELECT d.id, 'INSPECTION', qi.id, 1
FROM crm_drawing d
JOIN crm_quality_inspection qi ON qi.material_code COLLATE utf8mb4_unicode_ci = d.material_code COLLATE utf8mb4_unicode_ci
WHERE d.status IN ('DRAFT', 'RELEASED')
GROUP BY d.id, qi.id;

-- 5) 工单工序 → 图纸
INSERT IGNORE INTO crm_drawing_link (drawing_id, biz_type, biz_id, created_by)
SELECT d.id, 'WORKORDER_PROCESS', wp.id, 1
FROM crm_drawing d
JOIN crm_workorder_process wp ON wp.material_code COLLATE utf8mb4_unicode_ci = d.material_code COLLATE utf8mb4_unicode_ci
WHERE d.status IN ('DRAFT', 'RELEASED')
GROUP BY d.id, wp.id;

-- 回填率校验（运维巡检 SQL · 期望 ≥ 99%）
-- SELECT
--   (SELECT COUNT(*) FROM crm_drawing WHERE status IN ('DRAFT','RELEASED')) AS total_drawings,
--   (SELECT COUNT(DISTINCT drawing_id) FROM crm_drawing_link) AS linked_drawings,
--   ROUND((SELECT COUNT(DISTINCT drawing_id) FROM crm_drawing_link) * 100.0 /
--         (SELECT COUNT(*) FROM crm_drawing WHERE status IN ('DRAFT','RELEASED')), 2) AS coverage_pct;

-- 数据迁移后再做一次备份（确保 V54 部署后备份表是最新的）
INSERT IGNORE INTO crm_drawing_link_backup (id, drawing_id, biz_type, biz_id, created_at, created_by)
SELECT id, drawing_id, biz_type, biz_id, created_at, created_by FROM crm_drawing_link
ON DUPLICATE KEY UPDATE backup_at = CURRENT_TIMESTAMP;

