-- seed 30 attendance (10 员工 × 3 天 IN/OUT)
INSERT INTO crm_hr_attendance (employee_id, employee_no, clock_type, clock_at)
SELECT e.id, e.employee_no, x.clock_type, x.clock_at
FROM crm_hr_employee e
CROSS JOIN (
    SELECT 1 AS eid,'IN' AS clock_type,'2026-06-01 08:55:00' AS clock_at UNION ALL SELECT 1,'OUT','2026-06-01 18:05:00' UNION ALL SELECT 1,'IN','2026-06-02 08:50:00' UNION ALL SELECT 1,'OUT','2026-06-02 18:00:00' UNION ALL SELECT 1,'IN','2026-06-03 08:58:00' UNION ALL SELECT 1,'OUT','2026-06-03 18:10:00' UNION ALL
    SELECT 2,'IN','2026-06-01 08:30:00' UNION ALL SELECT 2,'OUT','2026-06-01 17:30:00' UNION ALL SELECT 2,'IN','2026-06-02 08:30:00' UNION ALL SELECT 2,'OUT','2026-06-02 17:30:00' UNION ALL SELECT 2,'IN','2026-06-03 08:30:00' UNION ALL SELECT 2,'OUT','2026-06-03 17:30:00' UNION ALL
    SELECT 3,'IN','2026-06-01 08:45:00' UNION ALL SELECT 3,'OUT','2026-06-01 18:00:00' UNION ALL SELECT 3,'IN','2026-06-02 08:50:00' UNION ALL SELECT 3,'OUT','2026-06-02 18:05:00' UNION ALL
    SELECT 4,'IN','2026-06-01 09:00:00' UNION ALL SELECT 4,'OUT','2026-06-01 18:30:00' UNION ALL SELECT 4,'IN','2026-06-02 09:00:00' UNION ALL SELECT 4,'OUT','2026-06-02 18:30:00' UNION ALL
    SELECT 5,'IN','2026-06-01 08:40:00' UNION ALL SELECT 5,'OUT','2026-06-01 18:20:00' UNION ALL
    SELECT 6,'IN','2026-06-01 08:35:00' UNION ALL SELECT 6,'OUT','2026-06-01 18:15:00' UNION ALL
    SELECT 7,'IN','2026-06-01 08:50:00' UNION ALL SELECT 7,'OUT','2026-06-01 18:00:00' UNION ALL
    SELECT 8,'IN','2026-06-01 08:00:00' UNION ALL SELECT 8,'OUT','2026-06-01 17:00:00' UNION ALL
    SELECT 9,'IN','2026-06-01 09:00:00' UNION ALL SELECT 9,'OUT','2026-06-01 18:00:00'
) x WHERE e.id = x.eid;

-- include: V39__hr_payroll.sql
-- V1.3.7 · Story 1.42 · 薪酬自动核算
CREATE TABLE IF NOT EXISTS crm_hr_payroll (
    id BIGINT AUTO_INCREMENT PRIMARY KEY COMMENT '主键ID',
    payroll_no VARCHAR(64) NOT NULL COMMENT '薪酬编号',
    period_year INT NOT NULL COMMENT 'periodyear',
    period_month INT NOT NULL COMMENT 'periodmonth',
    employee_id BIGINT NOT NULL COMMENT '员工ID',
    employee_no VARCHAR(64) NOT NULL COMMENT '员工编号',
    employee_name VARCHAR(64) NULL COMMENT '员工名称',
    base_salary DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT 'basesalary',
    position_salary DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT '岗位工资',
    piece_pay DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT '计件工资',
    performance_bonus DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT '绩效奖金',
    overtime_hours DECIMAL(8,2) NOT NULL DEFAULT 0 COMMENT 'overtimehours',
    overtime_pay DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT 'overtimepay',
    bonus DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT 'bonus',
    full_attendance_bonus DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT '全勤奖',
    deduction DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT 'deduction',
    social_insurance DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT '社保扣款',
    tax DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT 'tax',
    net_salary DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT 'netsalary',
    status VARCHAR(16) NOT NULL DEFAULT 'DRAFT' COMMENT '状态',
    approved_by BIGINT NULL COMMENT 'approvedby',
    approved_at DATETIME NULL COMMENT 'approved时间',
    created_by BIGINT NULL COMMENT '创建人用户ID',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
    UNIQUE KEY uk_payroll_no (payroll_no),
    UNIQUE KEY uk_emp_period (employee_id, period_year, period_month),
    KEY idx_payroll_period (period_year, period_month)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='薪酬单';

