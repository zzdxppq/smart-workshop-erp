-- 9) 工单表新增关联字段
SET @add_sales_order_id := (
    SELECT IF(COUNT(*) = 0,
        'ALTER TABLE crm_workorder ADD COLUMN sales_order_id BIGINT NULL COMMENT ''关联销售订单ID'' AFTER production_order_no',
        'SELECT ''skip crm_workorder.sales_order_id'' AS note')
