WHERE `menu_id` = (SELECT id FROM `sys_menu` WHERE `menu_code` = 'prod.schedule')
  AND `role_id` IN (SELECT id FROM `sys_role` WHERE `role_code` IN ('PROD_MGR', 'PRODUCTION_MANAGER'));

