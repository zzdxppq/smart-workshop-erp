-- include: V44__dashboard_outsource.sql
-- V1.3.7 · Story 1.47 · 报表·委外面板
CREATE TABLE IF NOT EXISTS crm_outsource_dashboard (
    id BIGINT AUTO_INCREMENT PRIMARY KEY COMMENT '主键ID',
    dashboard_no VARCHAR(64) NOT NULL COMMENT '看板编号',
    outsource_no VARCHAR(64) NULL COMMENT '委外单号',
    vendor_name VARCHAR(128) NULL COMMENT '厂商名称',
    status VARCHAR(32) NULL COMMENT '状态',
    metric_type VARCHAR(32) NULL COMMENT 'metrictype',
    metric_name VARCHAR(128) NULL COMMENT 'metric名称',
    metric_value DECIMAL(18,2) NOT NULL DEFAULT 0 COMMENT 'metricvalue',
    quality_pass_rate DECIMAL(5,2) NULL COMMENT '质量passrate',
    alert_level VARCHAR(16) NULL COMMENT '告警级别',
    snapshot_at DATETIME NOT NULL COMMENT '快照时间',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    UNIQUE KEY uk_dashboard_no (dashboard_no),
    KEY idx_status (status),
    KEY idx_metric_type (metric_type),
    KEY idx_alert (alert_level)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='委外看板';

