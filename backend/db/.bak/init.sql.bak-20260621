-- include: V76__hr_performance_payroll_scheme.sql
CREATE TABLE IF NOT EXISTS crm_hr_performance_scheme (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    scheme_name VARCHAR(64) NOT NULL COMMENT '方案名称',
    position VARCHAR(64) NULL COMMENT '适用岗位（空=通用）',
    output_weight DECIMAL(5,2) NOT NULL DEFAULT 40.00 COMMENT '产量权重%',
    quality_weight DECIMAL(5,2) NOT NULL DEFAULT 30.00 COMMENT '质量权重%',
    attendance_weight DECIMAL(5,2) NOT NULL DEFAULT 30.00 COMMENT '出勤权重%',
    is_default TINYINT NOT NULL DEFAULT 0,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    KEY idx_scheme_position (position)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='绩效考核方案';

CREATE TABLE IF NOT EXISTS crm_hr_salary_package (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    package_name VARCHAR(64) NOT NULL COMMENT '账套名称',
    position VARCHAR(64) NULL COMMENT '适用岗位',
    base_salary DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT '基本工资',
    position_salary DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT '岗位工资',
    piece_unit_price DECIMAL(10,4) NOT NULL DEFAULT 0 COMMENT '计件单价（元/件）',
    performance_a_rate DECIMAL(5,4) NOT NULL DEFAULT 0.2000 COMMENT 'A级绩效系数',
    performance_b_rate DECIMAL(5,4) NOT NULL DEFAULT 0.1000 COMMENT 'B级绩效系数',
    performance_c_rate DECIMAL(5,4) NOT NULL DEFAULT 0.0500 COMMENT 'C级绩效系数',
    performance_d_rate DECIMAL(5,4) NOT NULL DEFAULT 0.0000 COMMENT 'D级绩效系数',
    overtime_rate DECIMAL(5,2) NOT NULL DEFAULT 1.50 COMMENT '加班倍率',
    full_attendance_bonus DECIMAL(12,2) NOT NULL DEFAULT 0 COMMENT '全勤奖',
    social_insurance_rate DECIMAL(5,4) NOT NULL DEFAULT 0.1050 COMMENT '社保扣款比例',
    tax_threshold DECIMAL(12,2) NOT NULL DEFAULT 5000 COMMENT '个税起征点',
    tax_rate DECIMAL(5,4) NOT NULL DEFAULT 0.1000 COMMENT '个税税率',
    is_default TINYINT NOT NULL DEFAULT 0,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    KEY idx_pkg_position (position)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='工资账套';

INSERT INTO crm_hr_performance_scheme (scheme_name, position, output_weight, quality_weight, attendance_weight, is_default) VALUES
('操作工标准考核', 'CNC 操作员', 40.00, 30.00, 30.00, 1),
('质检员标准考核', '质检员', 30.00, 50.00, 20.00, 0)
ON DUPLICATE KEY UPDATE scheme_name = VALUES(scheme_name);

INSERT INTO crm_hr_salary_package (package_name, position, base_salary, position_salary, piece_unit_price, performance_a_rate, performance_b_rate, is_default) VALUES
('操作工标准账套', 'CNC 操作员', 4500.00, 2000.00, 8.5000, 0.2000, 0.1000, 1),
('管理岗标准账套', '车间主任', 6000.00, 2500.00, 0.0000, 0.1500, 0.0800, 0)
ON DUPLICATE KEY UPDATE package_name = VALUES(package_name);

UPDATE crm_hr_employee SET salary_package_id = 1, performance_scheme_id = 1, reviewer_user_id = 1
WHERE (position LIKE '%CNC%' OR position LIKE '%操作%') AND salary_package_id IS NULL;

UPDATE crm_hr_employee SET salary_package_id = 2, performance_scheme_id = 1, reviewer_user_id = 1
WHERE position = '车间主任' AND salary_package_id IS NULL;

-- include: V77__hr_performance_appeal.sql
CREATE TABLE IF NOT EXISTS crm_hr_performance_appeal (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    performance_id BIGINT NOT NULL COMMENT '绩效记录ID',
    employee_id BIGINT NOT NULL COMMENT '员工ID',
    employee_name VARCHAR(64) NULL COMMENT '员工姓名',
    period_year INT NOT NULL COMMENT '年份',
    period_month INT NOT NULL COMMENT '月份',
    reason TEXT NOT NULL COMMENT '申诉理由',
    status VARCHAR(16) NOT NULL DEFAULT 'PENDING' COMMENT 'PENDING/APPROVED/REJECTED',
    reviewer_user_id BIGINT NULL COMMENT '处理人用户ID',
    reply VARCHAR(500) NULL COMMENT '处理回复',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    resolved_at DATETIME NULL,
    KEY idx_appeal_emp (employee_id),
    KEY idx_appeal_perf (performance_id),
    KEY idx_appeal_status (status)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='绩效申诉';

-- include: V78__operator_hr_demo_seed.sql
USE `cnc_business`;

-- include: V79__link_app_users_hr_employee.sql（按 username 动态绑定，不硬编码 user_id）
UPDATE `crm_hr_employee` e
JOIN `cnc_platform`.`sys_user` u ON u.username = 'operator' AND u.status = 'ACTIVE'
SET e.user_id = u.id,
    e.salary_package_id = COALESCE(e.salary_package_id, 1),
    e.performance_scheme_id = COALESCE(e.performance_scheme_id, 1),
    e.reviewer_user_id = COALESCE(e.reviewer_user_id, 1)
WHERE e.employee_no = 'EM20260101-0002';

UPDATE `crm_hr_employee` e
JOIN `cnc_platform`.`sys_user` u ON u.username = 'qc' AND u.status = 'ACTIVE'
SET e.user_id = u.id,
    e.performance_scheme_id = COALESCE(e.performance_scheme_id, 2)
WHERE e.employee_no = 'EM20260101-0003';

UPDATE `crm_hr_employee` e
JOIN `cnc_platform`.`sys_user` u ON u.username = 'warehouse' AND u.status = 'ACTIVE'
SET e.user_id = u.id
WHERE e.employee_no = 'EM20260101-0008';

UPDATE `crm_hr_employee` e
JOIN `cnc_platform`.`sys_user` u ON u.username = 'prod_mgr' AND u.status = 'ACTIVE'
SET e.user_id = u.id
WHERE e.employee_no = 'EM20260101-0001';

UPDATE `crm_hr_employee` e
JOIN `cnc_platform`.`sys_user` u ON u.username = 'buyer' AND u.status = 'ACTIVE'
SET e.user_id = u.id
WHERE e.employee_no = 'EM20260101-0005';

UPDATE `crm_hr_employee` e
JOIN `cnc_platform`.`sys_user` u ON u.username = 'engineer' AND u.status = 'ACTIVE'
SET e.user_id = u.id
WHERE e.employee_no = 'EM20260101-0004';

UPDATE `crm_hr_employee` e
JOIN `cnc_platform`.`sys_user` u ON u.username = 'procurement_manager' AND u.status = 'ACTIVE'
SET e.user_id = u.id
WHERE e.employee_no = 'EM20260101-0005';

USE `cnc_platform`;
UPDATE `sys_user` SET `real_name` = '王芳' WHERE `username` = 'operator';

USE `cnc_business`;

SET @operator_uid = (SELECT id FROM `cnc_platform`.`sys_user` WHERE username = 'operator' AND status = 'ACTIVE' LIMIT 1);

DELETE FROM `crm_hr_payroll` WHERE `employee_id` = 2 AND `period_year` = 2026 AND `period_month` = 6;
DELETE FROM `crm_hr_performance` WHERE `employee_id` = 2 AND `period_year` = 2026 AND `period_month` = 6;
DELETE FROM `crm_production_report` WHERE `report_no` LIKE 'RP-OP13-%';
DELETE FROM `crm_production_scan` WHERE `scan_no` LIKE 'PS-OP13-%';
DELETE FROM `crm_employee_performance_daily` WHERE `operator_id` = @operator_uid AND `stat_date` >= '2026-06-01';
DELETE FROM `crm_hr_attendance` WHERE `employee_id` = 2 AND `clock_at` >= '2026-06-01' AND `clock_at` < '2026-07-01';

