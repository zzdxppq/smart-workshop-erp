-- include: V46__warehouse_incoming_permission.sql
-- V1.3.7 · Story 1.49 · 委外协同·仓管到货扫码权限
CREATE TABLE IF NOT EXISTS crm_warehouse_incoming_permission (
    id BIGINT AUTO_INCREMENT PRIMARY KEY COMMENT '主键ID',
    permission_no VARCHAR(64) NOT NULL COMMENT '权限编号',
    user_id BIGINT NOT NULL COMMENT '用户ID',
    user_name VARCHAR(64) NULL COMMENT '用户名称',
    role VARCHAR(32) NULL COMMENT '角色',
    permission_type VARCHAR(32) NULL COMMENT '权限type',
    valid_from DATETIME NOT NULL COMMENT 'validfrom',
    valid_to DATETIME NOT NULL COMMENT 'validto',
    granted_by VARCHAR(64) NULL COMMENT 'grantedby',
    status VARCHAR(16) NULL COMMENT '状态',
    email VARCHAR(128) NULL COMMENT '邮箱',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    UNIQUE KEY uk_permission_no (permission_no),
    KEY idx_user (user_id),
    KEY idx_status (status),
    KEY idx_valid (valid_to)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='仓管扫码权限';

