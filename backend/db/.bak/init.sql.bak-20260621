('OI20260612-0003', 3, 'WW20260612-0003', 103, '杭州线切割厂',  'ZZ-0004', 20, 16, 4, 20.00, 'FAILED', 301, '2026-06-30 14:00:00', 'qa@btsheng-163.com', 301),
