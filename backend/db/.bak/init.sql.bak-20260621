('OQ20260612-0002', 2, 'WW20260612-0002', '电镀锌', 102, '苏州电镀厂',    'FA',  1, 1, 0, 0.00,  0, 'PASSED', 301, '2026-06-28 11:00:00', 301),
('OQ20260612-0003', 3, 'WW20260612-0003', '线切割', 103, '杭州线切割厂',  'CMM', 1, 0, 1, 100.00, 1, 'FAILED', 301, '2026-06-30 14:00:00', 301),
('OQ20260612-0004', 4, 'WW20260612-0004', '喷涂',   104, '宁波喷涂厂',    'FA',  1, 1, 0, 0.00,  0, 'PASSED', 301, '2026-07-05 09:00:00', 301),
('OQ20260612-0005', 3, 'WW20260612-0003', '线切割', 103, '杭州线切割厂',  'CMM', 1, 0, 1, 100.00, 1, 'FAILED', 301, '2026-07-01 15:00:00', 301);

