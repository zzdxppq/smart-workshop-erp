-- include: V45__dashboard_material_price.sql
-- V1.3.7 · Story 1.48 · 报表·料号价格面板
CREATE TABLE IF NOT EXISTS crm_material_price_dashboard (
    id BIGINT AUTO_INCREMENT PRIMARY KEY COMMENT '主键ID',
    dashboard_no VARCHAR(64) NOT NULL COMMENT '看板编号',
    material_code VARCHAR(64) NOT NULL COMMENT '物料编码',
    material_name VARCHAR(128) NULL COMMENT '物料名称',
    vendor_name VARCHAR(128) NULL COMMENT '厂商名称',
    price DECIMAL(18,4) NOT NULL DEFAULT 0 COMMENT 'price',
    price_period VARCHAR(32) NULL COMMENT 'priceperiod',
    price_type VARCHAR(32) NULL COMMENT 'pricetype',
    cost_total DECIMAL(18,2) NULL COMMENT '总成本',
    price_trend DECIMAL(8,2) NULL COMMENT 'pricetrend',
    snapshot_at DATETIME NOT NULL COMMENT '快照时间',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
    UNIQUE KEY uk_dashboard_no (dashboard_no),
    UNIQUE KEY uk_material_price_slice (material_code, price_type, price_period, vendor_name),
    KEY idx_vendor (vendor_name),
    KEY idx_period (price_period),
    KEY idx_material_type (material_code, price_type)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='料号价格看板';

