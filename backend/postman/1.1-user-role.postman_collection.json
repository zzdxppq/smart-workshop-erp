{
  "info": {
    "name": "Story 1.1 - 用户与角色权限",
    "description": "V1.3.7 · auth × 3 + users × 5 + roles × 5 + audit × 1 + quote × 1 = 15 端点（覆盖 Story 1.1 全部 AC）",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth - 登录 (成功)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] },
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"admin\",\"password\":\"Admin@123\"}"
        }
      },
      "event": [{
        "listen": "test",
        "script": { "exec": ["pm.collectionVariables.set('accessToken', pm.response.json().data.accessToken);", "pm.expect(pm.response.json().code).to.eql(0);"] }
      }]
    },
    {
      "name": "2. Auth - 登录失败 (5次锁)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] },
        "body": { "mode": "raw", "raw": "{\"username\":\"admin\",\"password\":\"wrong\"}" }
      }
    },
    {
      "name": "3. Auth - 当前用户 /me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "me"] }
      }
    },
    {
      "name": "4. Auth - 登出 /logout",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout"] }
      }
    },
    {
      "name": "5. Users - 列表 (分页 + 数据权限)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/users?pageNum=1&pageSize=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "users"],
          "query": [{ "key": "pageNum", "value": "1" }, { "key": "pageSize", "value": "20" }]
        }
      }
    },
    {
      "name": "6. Users - 创建用户 zhangsan (AC-1.1.1)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/v1/users", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"] },
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"zhangsan\",\"password\":\"Pass1234\",\"realName\":\"张三\",\"phone\":\"13800000000\",\"email\":\"zhangsan@byts.com\",\"roleCodes\":[\"SALES\"]}"
        }
      }
    },
    {
      "name": "7. Users - 查询用户 /{id}",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/users/10086", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "10086"] }
      }
    },
    {
      "name": "8. Users - 更新用户 /{id}",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/v1/users/10086", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "10086"] },
        "body": { "mode": "raw", "raw": "{\"realName\":\"张三三\",\"phone\":\"13800000001\"}" }
      }
    },
    {
      "name": "9. Users - 禁用用户 /{id} (BR-4 黑名单)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/users/10086", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "10086"] }
      }
    },
    {
      "name": "10. Roles - 列表",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/roles", "host": ["{{baseUrl}}"], "path": ["api", "v1", "roles"] }
      }
    },
    {
      "name": "11. Roles - 查询 /{id}",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/roles/2", "host": ["{{baseUrl}}"], "path": ["api", "v1", "roles", "2"] }
      }
    },
    {
      "name": "12. Roles - 分配权限 /{id}/permissions (AC-1.1.2)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/v1/roles/2/permissions", "host": ["{{baseUrl}}"], "path": ["api", "v1", "roles", "2", "permissions"] },
        "body": {
          "mode": "raw",
          "raw": "[{\"menuId\":1001,\"actions\":[\"view\",\"add\",\"edit\"]},{\"menuId\":1002,\"actions\":[\"view\"]}]"
        }
      }
    },
    {
      "name": "13. Roles - 更新金额阈值 (T3.4 实时生效)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/v1/roles/2", "host": ["{{baseUrl}}"], "path": ["api", "v1", "roles", "2"] },
        "body": { "mode": "raw", "raw": "{\"roleName\":\"业务员\",\"amountThreshold\":100000}" }
      }
    },
    {
      "name": "14. Roles - 删除 /{id} (BR-11/12 守卫)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/roles/50", "host": ["{{baseUrl}}"], "path": ["api", "v1", "roles", "50"] }
      }
    },
    {
      "name": "15. Quote - 提交 60000 (AC-1.1.3 路由)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "X-User-Id", "value": "10086" }
        ],
        "url": { "raw": "{{baseUrl}}/api/v1/quotes", "host": ["{{baseUrl}}"], "path": ["api", "v1", "quotes"] },
        "body": { "mode": "raw", "raw": "{\"amount\":60000,\"customerId\":1}" }
      }
    },
    {
      "name": "16. Audit - 审计日志查询 (P1 修补 admin 限定)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/audit/logs?bizType=user.create&operatorId=1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "audit", "logs"],
          "query": [{ "key": "bizType", "value": "user.create" }, { "key": "operatorId", "value": "1" }]
        }
      }
    }
  ]
}
