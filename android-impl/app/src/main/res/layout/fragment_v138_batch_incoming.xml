<?xml version="1.0" encoding="utf-8"?>
<!-- V1.3.8 Sprint 8 Story 8.5 · 分批到货扫码 Fragment layout -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="分批到货（PO · Story 3.1）"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="演示 PO ID：1001（PO20260615-0001）"
            android:textSize="12sp"
            android:paddingBottom="12dp" />

        <EditText
            android:id="@+id/etPoId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="PO ID"
            android:inputType="number"
            android:text="1001" />

        <Button
            android:id="@+id/btnLoadPo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="加载 PO 状态" />

        <TextView
            android:id="@+id/tvPoStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:textSize="13sp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/etMaterialList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="top"
            android:hint="物料清单，每行：materialId,quantity&#10;例：5001,60"
            android:minLines="3" />

        <Button
            android:id="@+id/btnSubmitBatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="提交批次" />

        <ProgressBar
            android:id="@+id/progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:textColor="#2E7D32"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:textColor="#D32F2F"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
